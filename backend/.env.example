# PostgreSQL — replace with AWS RDS endpoint in production
DATABASE_URL=postgresql+asyncpg://medlens:medlens@localhost:5432/medlens

# JWT
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AWS (S3 for image storage, EventBridge for audit events)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=medlens-images

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000
